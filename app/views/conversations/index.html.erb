<h2><%= @partner.name %> と会話</h2>

<%= form_with url: conversations_path(partner_id: @partner.id),
              method: :post,
              data: { turbo: false } do %>

  <%= text_area_tag :message, nil, rows: 4, cols: 50 %>

  <br>

  <%= submit_tag "送信" %>

<% end %>

<hr>

<% @conversations.each do |conversation| %>

  <% if conversation.speaker == "user" %>
    <p><strong>あなた</strong></p>
  <% else %>
    <p><strong><%= @partner.name %></strong></p>
  <% end %>

  <p><%= conversation.message %></p>

<% end %>

<hr>

<%= button_to "会話履歴を削除",
      destroy_all_conversations_path(partner_id: @partner.id),
      method: :delete,
      data: {
        turbo_confirm: "本当に会話履歴を削除しますか？"
      } %>