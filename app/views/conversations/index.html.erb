<div class="game-screen">

  <div class="status">
    <div class="status-header">
      <%= link_to "🏠 HOME", home_index_path, class: "home-button" %>
    </div>

    <h2 class="partner-name">
      <%= @partner.name %>
    </h2>

    <div class="affection-area">

      <div class="affection-label">
        ❤️ 好感度
        <span><%= @user_partner.affection %>/100</span>
      </div>

      <div class="gauge">

        <div class="gauge-bar"
            style="width:<%= [@user_partner.affection,0].max %>%;">
        </div>

      </div>

    </div>

    <p class="status-text">
      🌸 <%= @user_partner.status %>
    </p>

  </div>

  <div class="main-area">

    <div class="message-window" id="message-window">

      <% if @conversations.any? %>

        <% @conversations.each do |conversation| %>

          <div class="message <%= conversation.speaker %>">

            <strong>
              <%= conversation.speaker == "user" ? "あなた" : @partner.name %>
            </strong>

            <p><%= conversation.message %></p>

          </div>

        <% end %>

      <% end %>

    </div>

    <div class="character">

      <%= image_tag "#{@partner.name}.png",
            class: "partner-image",
            id: "character-image" %>

    </div>

  </div>

  <div class="input-window">

    <%= form_with url: conversations_path(partner_id: @partner.id),
                  method: :post,
                  data: { turbo: false } do %>

      <%= text_area_tag :message %>

      <%= submit_tag "送信", class: "send-button" %>

    <% end %>

  </div>

  <div
    id="event-popup"
    data-message="<%= flash[:event] %>">
  </div>

  <div class="history-delete">
    <%= button_to "会話履歴を削除",
          destroy_all_conversations_path(partner_id: @partner.id),
          method: :delete,
          data: {
            turbo_confirm: "本当に会話履歴を削除しますか？"
          } %>
  </div>

</div>